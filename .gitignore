# ==========================================
# 1. 가상 환경 (Virtual Environment)
# ==========================================
# Python 가상 환경 폴더는 용량도 크고 로컬 환경마다 달라서 절대 올리면 안 됩니다.
.venv/
venv/
env/
ENV/
.env/

# ==========================================
# 2. 민감한 정보 및 환경 변수 (Secrets & Config)
# ==========================================
# API 키, DB 비밀번호 등이 들어가는 파일들
.env
.env.local
.env.*
secrets.json
config_local.py

# ==========================================
# 3. 데이터베이스 및 데이터 파일 (Data & DB)
# ==========================================
# 우리가 다루는 대용량 CSV 파일이나 로컬 DB 파일 (선택 사항)
# 만약 master_rdb.csv를 공유해야 한다면 이 부분은 주석 처리하세요.
# *.csv
*.sqlite3
*.db

# ==========================================
# 4. 파이썬 캐시 파일 (Python Cache)
# ==========================================
# 파이썬이 실행될 때 임시로 만드는 찌꺼기 파일들
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 5. IDE 및 에디터 설정 (IDE & Editors)
# ==========================================
# VSCode, PyCharm 등 에디터별 개인 설정 파일들
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# 6. 기타 임시 파일
# ==========================================
.DS_Store # Mac 사용자용
logs/
*.log